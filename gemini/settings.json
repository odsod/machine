{
  "context": {
    "fileName": ["AGENTS.md", "README.md"],
    "fileFiltering": {
      "respectGitIgnore": false
    },
    "loadMemoryFromIncludeDirectories": false
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "/home/odsod/.gemini/hooks/rtk-hook-gemini.sh"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "notify-completion",
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          },
          {
            "name": "jj-snapshot",
            "type": "command",
            "command": "test -d .jj && jj st > /dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "notify-alert",
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ]
  },
  "security": {
    "auth": {
      "selectedType": "vertex-ai"
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "ui": {
    "hideBanner": true,
    "useAlternateBuffer": true,
    "incrementalRendering": true,
    "accessibility": {
      "enableLoadingPhrases": false
    },
    "hideTips": true,
    "showCitations": true,
    "showLineNumbers": true,
    "showMemoryUsage": true,
    "footer": {
      "hideModelInfo": false,
      "hideSandboxStatus": true,
      "hideContextPercentage": false
    },
    "theme": "Default",
    "loadingPhrases": "off"
  },
  "output": {
    "format": "text"
  },
  "general": {
    "vimMode": true,
    "defaultApprovalMode": "auto_edit",
    "enableAutoUpdate": false,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "plan": {
      "enabled": true
    }
  },
  "tools": {
    "sandbox": false
  },
  "experimental": {},
  "agents": {
    "overrides": {}
  }
}
