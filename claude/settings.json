{
  "awsAuthRefresh": "aws sso login --profile bedrock",
  "respectGitignore": false,
  "cleanupPeriodDays": 3650,
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_PROFILE": "bedrock",
    "AWS_REGION": "eu-north-1",
    "ANTHROPIC_SMALL_FAST_MODEL_AWS_REGION": "eu-north-1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "CLAUDE_CODE_NO_FLICKER": "0",
    "PLANNOTATOR_BROWSER": "plannotator-browser",
    "PLANNOTATOR_REMOTE": "0",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "eu.anthropic.claude-opus-4-6-v1[1m]",
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; case \"$f\" in *.md|*.yaml|*.yml|*.json|*.toml) oxfmt --write \"$f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bell"
          },
          {
            "type": "command",
            "command": "test -d .jj && jj st > /dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bell"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "plannotator@plannotator": true
  },
  "effortLevel": "xhigh",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark"
}
